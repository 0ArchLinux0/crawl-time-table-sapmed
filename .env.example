# ============================================
# 1) 이 파일을 복사해서 `.env` 로 저장한 뒤 값만 채우세요.
#    PowerShell:  Copy-Item .env.example .env
# ============================================

# --- SMU portal (필수) ---
# 학교 메일 전체 주소 권장 (예: a25m080@sapmed.ac.jp)
PORTAL_USER=
PORTAL_PASS=

# PORTAL_USER가 학번만 있을 때만 도메인 지정
# PORTAL_USER_DOMAIN=stu.sapmed.ac.jp

# --- Notion (notion_sync · 파이프라인에 필수) ---
# Notion Integration → Internal Integration Secret
NOTION_TOKEN=
# DB URL에 있는 32자리 ID (하이픈 있어도 됨)
NOTION_DB_ID=

# DB가 워크스페이스 직속이면 갱신 로그/경고는 이 페이지에 붙입니다.
# 페이지 URL에서 ID 복사 (integration에 페이지 공유 필요)
# NOTION_SYNC_LOG_PAGE_ID=
# NOTION_SYNC_LOG_STYLE=toggle

# 준비물 체크리스트(봇 /pack): to-do 블록을 붙일 부모 페이지 ID. 비우면 기본(10_MEDICAL 페이지) 사용.
# NOTION_PACK_PAGE_ID=339442f6b46d4c849edb487a4db293b5
# 스케줄 동기화(run_pipeline / smu_scheduler) 성공 직후 노션 준비물 체크 전부 해제 (1=사용)
# PACK_RESET_ON_SCHEDULE_SYNC=1

# ============================================
# --- Telegram 알림 (선택, 권장) ---
# 파이프라인 실패·빈 시간표·강의실 스크랩≠규칙 불일치 시 푸시
#
# [필요한 정보 — 본인이 채움]
#
# (A) TELEGRAM_BOT_TOKEN
#     1. 텔레그램에서 @BotFather 검색
#     2. /newbot → 이름 지정 → **HTTP API token** 복사 (예: 7123456789:AAHxxx...)
#
# (B) TELEGRAM_CHAT_ID
#     - 본인 계정으로 봇에게 아무 말이나 보내고 (/start)
#     - 브라우저에서 열기 (TOKEN을 아래에 붙여넣기):
#         https://api.telegram.org/bot<TOKEN>/getUpdates
#     - "chat":{"id": 123456789} ← 이 숫자만 CHAT_ID에 넣음 (마이너스면 그룹)
#     - 또는 @userinfobot 에게 메시지 → id 표시
#
# 연결 확인:
#     .\.venv\Scripts\python.exe scripts\test_telegram.py
#
# 채팅 명령으로 워커 실행(오케스트레이터): BOT.md 참고 → main_bot.py
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
#
# 수업 시작 전 알림 (로컬 schedule.json, 일본 시간 · TELEGRAM_CHAT_ID 로 전송)
# main_bot 데몬이 돌아가야 함. 하루 1교시당 1회만 전송(artifacts/class_reminders_sent.json).
# SCHEDULE_CLASS_REMINDERS=1
# CLASS_REMINDER_MINUTES_BEFORE=10

# --- Gemini (봇 /gemini) — 키는 AI Studio에서 발급 권장 https://aistudio.google.com/apikey
# (GCP 콘솔 키는 스코프/API 설정이 어긋나 404·권한 오류가 잦음)
GEMINI_API_KEY=
# 모델명은 list_models 에 나온 짧은 id (예: gemini-2.0-flash). models/ 접두사는 넣어도 코드에서 제거.
# 사용 가능 목록:  .\.venv\Scripts\python.exe scripts\check_models.py
# 코드 기본값: fast/think/pro = gemini-2.5-flash (무응답·hang 시 자동 폴백)
# GEMINI_MODEL_FAST=gemini-2.5-flash
# GEMINI_MODEL_THINK=gemini-2.5-flash
# GEMINI_MODEL_PRO=gemini-2.5-flash
# 유료·높은 쿼터만 예: GEMINI_MODEL_PRO=gemini-2.5-pro
# 404/429 시 순차 시도: GEMINI_MODEL_FALLBACKS=gemini-flash-latest,gemini-2.5-flash
# 429 대비 재시도: GEMINI_MAX_RETRIES=6  GEMINI_RETRY_BASE_SEC=2
# 단일 HTTP 타임아웃(초, 일부 경로만 적용): GEMINI_HTTP_TIMEOUT_SEC=60
# 모델 1회 호출 최대 대기(초, hang 방지·필수): GEMINI_PER_CALL_DEADLINE_SEC=55
# 봇 명령 전체 상한(초): GEMINI_BOT_COMMAND_TIMEOUT_SEC=300
# 사고 모델이 네이티브 추론이면 프롬프트 래핑 끄기: GEMINI_THINK_USE_PROMPT_WRAP=0

# --- DeepSeek (봇 /deepseek) — https://platform.deepseek.com/api_keys ---
DEEPSEEK_API_KEY=
# 선택: 기본 https://api.deepseek.com (OpenAI 호환 path /chat/completions)
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL_FAST=deepseek-chat
# DEEPSEEK_MODEL_THINK=deepseek-reasoner
# DEEPSEEK_MODEL_PRO=deepseek-chat
# think 에 추가 프롬프트 래핑 켜기: DEEPSEEK_THINK_USE_PROMPT_WRAP=1

# --- Slack (선택, Telegram 대신/추가) ---
# Incoming Webhook URL 한 줄
# SLACK_WEBHOOK_URL=
